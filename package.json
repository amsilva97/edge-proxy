{
  "name": "edge-proxy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=$(grep -sh '^NEXT_PUBLIC_PORT=' .env.local .env | head -1 | cut -d= -f2) && next dev -H 0.0.0.0 -p ${PORT:-3000}",
    "build": "next build",
    "start": "PORT=$(grep -sh '^NEXT_PUBLIC_PORT=' .env.local .env | head -1 | cut -d= -f2) && next start -p ${PORT:-3000}",
    "lint": "eslint"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}